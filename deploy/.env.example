# LocalMaps — dev/.env example.
#
# Every variable here is sourced from docs/07-config-schema.md (the
# "Boot-time (env vars)" section). Runtime-tunable settings live in
# the SQLite settings table, NOT here.
#
# Copy this file to `.env` next to docker-compose.yml before `up`:
#   cp deploy/.env.example deploy/.env
# In a Kubernetes/Helm deploy these come from the pod spec, not .env.

# ----- Gateway / worker boot env (docs/07-config-schema.md) -----

# Where region data + config.db + cache go. Mounted as ./data in compose.
LOCALMAPS_DATA_DIR=/data

# Gateway HTTP listen address (inside the container).
LOCALMAPS_LISTEN_ADDR=:8080

# Asynq + rate-limit backend. Service name "redis" resolves on the
# compose network.
LOCALMAPS_REDIS_URL=redis://redis:6379/0

# Internal tile server (go-pmtiles serve).
LOCALMAPS_PROTOMAPS_URL=http://protomaps:8000

# Internal routing server (Valhalla).
LOCALMAPS_VALHALLA_URL=http://valhalla:8002

# Internal geocoder (Pelias API).
LOCALMAPS_PELIAS_URL=http://pelias-api:4000

# Binary role switch — "gateway" or "worker". The compose file
# overrides this per container; the default suits a one-off run.
LOCALMAPS_MODE=gateway

# zerolog level: trace | debug | info | warn | error | fatal.
LOCALMAPS_LOG_LEVEL=info

# Set true only when an external reverse proxy terminates TLS and
# rewrites request URLs. Leave false for a plain `docker compose up`.
LOCALMAPS_TRUST_PROXY_HEADERS=false
