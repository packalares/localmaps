{
  "name": "localmaps-ui",
  "version": "0.1.0",
  "private": true,
  "description": "LocalMaps UI — Next.js App Router frontend for the self-hosted maps platform.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
