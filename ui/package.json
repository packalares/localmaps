    "@types/node": "20.19.39",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "5.1.4",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "10.5.0",
    "eslint": "8.57.1",
    "eslint-config-next": "15.5.15",
    "jsdom": "26.1.0",
    "openapi-typescript": "7.13.0",
    "postcss": "8.5.10",
    "prettier": "3.8.3",
    "tailwindcss": "3.4.19",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
