    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-toast": "1.2.15",
    "@radix-ui/react-tooltip": "1.2.8",
    "@tanstack/react-query": "5.100.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "lucide-react": "1.9.0",
    "maplibre-gl": "4.7.1",
    "next": "15.5.15",
    "pmtiles": "3.2.1",
    "qrcode.react": "3.2.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwind-merge": "3.5.0",
